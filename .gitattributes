# Force LF for scripts and code — prevents CRLF issues when running in WSL/Linux
*.sh    text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Binary files — no line ending conversion
*.jpg   binary
*.jpeg  binary
*.png   binary
*.svg   binary
*.gif   binary

